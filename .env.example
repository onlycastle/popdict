# Supabase (auth + saved words + idiom proxy)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Public GitHub repo used by release builds for auto-update and feedback links.
# Set as an environment variable when building a public release.
POPDICT_GITHUB_REPO=owner/repo

# Idiom lookups are served by the `idioms` Supabase Edge Function so the STANDS4
# token never ships in the app. Set the token as a Supabase secret (NOT here):
#   supabase secrets set STANDS4_UID=... STANDS4_TOKEN=...
# See IDIOM_SETUP.md.
