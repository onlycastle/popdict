# Supabase (auth + saved words + multilingual equivalents) — OPTIONAL.
# Leave these BLANK to run PopDict with basic dictionary lookup only; the app
# treats Supabase as "not configured" and cleanly disables account features.
# To enable those features, fill in your own project's values, e.g.:
#   VITE_SUPABASE_URL=https://your-project-ref.supabase.co
#   VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
# Use the publishable key. Older projects can instead set VITE_SUPABASE_ANON_KEY
# (the app accepts either). Never put the service_role key in the client.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Supabase OAuth should normally return to the web callback, which forwards the
# result into the desktop app and leaves Chrome on a completed page.
VITE_SUPABASE_AUTH_REDIRECT_URL=https://popdict.space/auth/callback

# Public GitHub repo used by release builds for auto-update and feedback links.
# Set as an environment variable when building a public release.
POPDICT_GITHUB_REPO=owner/repo
