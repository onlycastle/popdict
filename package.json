{
  "name": "popdict",
  "productName": "PopDict",
  "version": "1.4.0",
  "description": "PopDict desktop dictionary app",
  "main": ".vite/build/main.js",
  "homepage": "https://github.com/onlycastle/popdict#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onlycastle/popdict.git"
  },
  "bugs": {
    "url": "https://github.com/onlycastle/popdict/issues"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make && node scripts/notarize-dmg.js",
    "make:local": "POPDICT_SKIP_MAC_SIGNING=1 npm run package && node create-dmg.js",
    "make:mac:arm64": "electron-forge make --platform=darwin --arch=arm64 && node scripts/notarize-dmg.js",
    "make:mac:x64": "electron-forge make --platform=darwin --arch=x64 && node scripts/notarize-dmg.js",
    "make:all": "electron-forge make",
    "notarize:dmg": "node scripts/notarize-dmg.js",
    "release:arm64": "./scripts/release-arm64.sh",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness:validate": "node scripts/harness/validate.mjs",
    "harness:test": "vitest run scripts/harness",
    "preview:digest": "deno run --allow-env --allow-read --allow-write --allow-net --allow-run scripts/preview-digest.ts",
    "test:ci": "tsc --noEmit && npm run lint && npm test && npm run harness:validate && cd site && npx tsc --noEmit && npx vitest run"
  },
  "keywords": [
    "electron",
    "macos",
    "dictionary",
    "menu-bar",
    "english-learning",
    "vocabulary",
    "idioms",
    "supabase"
  ],
  "author": "PopDict contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^6.0.3",
    "appdmg": "^0.6.6",
    "autoprefixer": "^10.4.20",
    "create-dmg": "^7.1.0",
    "electron": "39.8.10",
    "electron-installer-dmg": "^5.0.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fast-xml-parser": "^5.9.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@supabase/supabase-js": "2.108.2",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "tar": "^7.5.19",
    "tmp": "^0.2.7"
  }
}
