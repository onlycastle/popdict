# Public site URL (used for SEO / Open Graph metadata)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# GitHub "owner/repo" that hosts PopDict releases and public issue links.
GITHUB_REPO=owner/repo

# Server-only Slack Incoming Webhook for signup/sign-in notifications.
# Do not expose this as NEXT_PUBLIC_*.
SLACK_SIGNUP_WEBHOOK_URL=https://hooks.slack.com/services/...
