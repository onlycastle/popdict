# Public site URL (used for SEO / Open Graph metadata)
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# GitHub "owner/repo" that hosts PopDict releases and public issue links.
GITHUB_REPO=owner/repo

# Server-only download tracking and private dashboard configuration.
# All values below are documented-fake placeholders.
DOWNLOADS_FN_URL=https://functions.example.invalid/downloads
DOWNLOADS_RECORD_TOKEN=replace-with-random-record-token
DOWNLOADS_STATS_TOKEN=replace-with-random-stats-token
DOWNLOADS_DASHBOARD_USER=replace-with-dashboard-user
DOWNLOADS_DASHBOARD_PASSWORD=replace-with-random-password
CRON_SECRET=replace-with-random-cron-secret
