# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies — slash-free so the pattern also matches the worktree
# node_modules *symlink* (L-009); a trailing-slash pattern is directory-only.
**/node_modules

# Build output and generated caches
build/
dist/
dist-electron/
dist-ssr/
out/
output/
.vite/
site/.next/
.cache/
coverage/
.nyc_output/
*.tsbuildinfo

# Release artifacts
release/
releases/
artifacts/
*.dmg
*.pkg
*.zip
*.blockmap

# Environment and local service metadata
.env
.env.*
!.env.example
!.env.*.example
site/.env
site/.env.*
!site/.env.example
supabase/.temp/

# Private keys, certificates, and signing material
*.pem
*.key
*.p8
*.p12
*.cer
*.crt
*.csr
*.mobileprovision

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Agent / AI tooling local state — never upload to the public repo
.superpowers/
# .claude is local state EXCEPT skills, which are tracked so agents and
# contributors share the same specialist playbooks (git cannot re-include
# below an excluded directory, hence the /* form).
.claude/*
!.claude/skills/
docs/superpowers/

# Local-only reports (security findings, audits) — keep out of the public repo
security_best_practices_report.md

# Deno lockfile from edge-function tests — regenerated locally; the deployed
# functions resolve imports at deploy time (matches the lockfile-free `idioms` fn)
deno.lock

# Local demo recordings — keep large binaries out of the public repo
*.mp4

# ETL build artifacts
out-data/
